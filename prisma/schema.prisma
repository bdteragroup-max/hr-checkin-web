generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model admins {
  id            Int        @id @default(autoincrement())
  username      String     @unique @db.VarChar(50)
  password_hash String
  full_name     String?    @db.VarChar(100)
  last_login    DateTime?  @db.Timestamptz(6)
  created_at    DateTime   @default(now()) @db.Timestamptz(6)
  sessions      sessions[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model branches {
  id         String      @id @db.VarChar(10)
  name       String      @db.VarChar(100)
  center_lat Decimal     @db.Decimal(10, 8)
  center_lon Decimal     @db.Decimal(11, 8)
  radius_m   Int
  created_at DateTime    @default(now()) @db.Timestamptz(6)
  updated_at DateTime    @default(now()) @db.Timestamptz(6)
  employees  employees[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model checkins {
  id           BigInt   @id @default(autoincrement())
  timestamp    DateTime @default(now()) @db.Timestamptz(6)
  date_key     DateTime @db.Date
  time_key     DateTime @db.Time(6)
  emp_id       String   @db.VarChar(50)
  name         String   @db.VarChar(200)
  type         String   @db.VarChar(50)
  branch_name  String   @db.VarChar(200)
  lat          Decimal? @db.Decimal(10, 8)
  lon          Decimal? @db.Decimal(11, 8)
  accuracy     Int?
  distance     Int?
  capture_mode String   @default("webrtc") @db.VarChar(50)
  late_status  String?  @db.VarChar(50)
  late_min     Int?
  photo_url    String?
  project_name String?  @db.VarChar(200)
  remark       String?
  customer_id  Int?

  @@index([branch_name], map: "idx_checkins_branch")
  @@index([date_key], map: "idx_checkins_date")
  @@index([emp_id, date_key], map: "idx_checkins_emp_date")
}

model ot_requests {
  id             Int       @id @default(autoincrement())
  emp_id         String    @db.VarChar(20)
  date_for       DateTime  @db.Date
  start_time     DateTime  @db.Timestamptz(6)
  end_time       DateTime  @db.Timestamptz(6)
  total_hours    Decimal   @db.Decimal(5, 2)
  reason         String?
  status         String    @default("pending") @db.VarChar(20)
  supervisor_id  String?   @db.VarChar(20)
  approved_at    DateTime? @db.Timestamptz(6)
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime  @default(now()) @db.Timestamptz(6)
  approved_hours Decimal?  @db.Decimal(5, 2)
  employee       employees @relation("EmployeeToOtRequests", fields: [emp_id], references: [emp_id], onDelete: Cascade)

  @@index([emp_id, date_for])
  @@index([status])
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model employees {
  emp_id                  String              @id @db.VarChar(20)
  name                    String              @db.VarChar(100)
  branch_id               String?             @db.VarChar(10)
  is_active               Boolean             @default(true)
  created_at              DateTime            @default(now()) @db.Timestamptz(6)
  updated_at              DateTime            @default(now()) @db.Timestamptz(6)
  pin_hash                String?
  gender                  String?             @db.VarChar(1)
  hire_date               DateTime?           @db.Date
  birth_date              DateTime?           @db.Date
  phone_number            String?             @db.VarChar(20)
  base_salary             Decimal?            @db.Decimal(12, 2)
  department_id           Int?
  job_position_id         Int?
  otp_code                String?             @db.VarChar(6)
  otp_expires_at          DateTime?           @db.Timestamptz(6)
  supervisor_id           String?             @db.VarChar(20)
  bank_account_no         String?             @db.VarChar(50)
  bank_name               String?             @db.VarChar(100)
  is_on_trial             Boolean             @default(false)
  has_telephone_allowance Boolean             @default(false)
  position_allowance      Decimal?            @default(0) @db.Decimal(12, 2)
  birthday_claims         birthday_claims[]
  warnings                employee_warnings[]
  departments             departments?        @relation(fields: [department_id], references: [id], onUpdate: NoAction)
  job_positions           job_positions?      @relation(fields: [job_position_id], references: [id], onUpdate: NoAction)
  supervisor              employees?          @relation("EmployeeToSupervisor", fields: [supervisor_id], references: [emp_id], onUpdate: NoAction)
  subordinates            employees[]         @relation("EmployeeToSupervisor")
  branches                branches?           @relation(fields: [branch_id], references: [id], onUpdate: NoAction, map: "fk_employees_branch")
  ot_requests             ot_requests[]       @relation("EmployeeToOtRequests")
  travel_claims           travel_claims[]

  @@index([is_active], map: "idx_employees_active")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model holidays {
  date       DateTime @id @db.Date
  name       String   @db.VarChar(100)
  created_at DateTime @default(now()) @db.Timestamptz(6)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model leave_requests {
  id                     String    @id @db.VarChar(30)
  timestamp              DateTime  @default(now()) @db.Timestamptz(6)
  emp_id                 String    @db.VarChar(20)
  name                   String    @db.VarChar(100)
  leave_type_id          String    @db.VarChar(20)
  leave_type             String    @db.VarChar(50)
  start_date             DateTime  @db.Date
  end_date               DateTime  @db.Date
  days                   Int
  reason                 String?
  status                 String    @default("pending") @db.VarChar(20)
  approved_by            String?   @db.VarChar(100)
  approved_at            DateTime? @db.Timestamptz(6)
  start_at               DateTime  @db.Timestamptz(6)
  end_at                 DateTime  @db.Timestamptz(6)
  minutes                Int
  attachment_url         String?
  supervisor_approved_at DateTime? @db.Timestamptz(6)
  supervisor_id          String?   @db.VarChar(20)

  @@index([start_date, end_date], map: "idx_leave_dates")
  @@index([emp_id, status], map: "idx_leave_emp_status")
  @@index([emp_id, start_at, end_at], map: "idx_leave_emp_time")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model sessions {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token      String
  expires_at DateTime @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  admins     admins   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_sessions_admin")

  @@index([token], map: "idx_sessions_token")
}

model admin_login_attempts {
  id         BigInt   @id @default(autoincrement())
  username   String   @db.VarChar(50)
  ip         String   @db.VarChar(64)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@index([ip, created_at], map: "idx_admin_attempts_ip_time")
  @@index([username, created_at], map: "idx_admin_attempts_user_time")
}

model leave_entitlements {
  id            Int         @id @default(autoincrement())
  leave_type_id String      @db.VarChar(20)
  min_years     Int
  days          Int
  leave_types   leave_types @relation(fields: [leave_type_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([leave_type_id, min_years])
}

model leave_types {
  id                 String               @id @db.VarChar(20)
  name               String               @db.VarChar(80)
  gender_rule        String               @default("ALL") @db.VarChar(10)
  max_days           Int?
  count_mode         String               @default("WORK") @db.VarChar(12)
  require_attachment Boolean              @default(false)
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  updated_at         DateTime             @default(now()) @db.Timestamptz(6)
  leave_entitlements leave_entitlements[]
}

model departments {
  id            Int             @id @default(autoincrement())
  name          String          @db.VarChar(100)
  created_at    DateTime        @default(now()) @db.Timestamptz(6)
  updated_at    DateTime        @default(now()) @db.Timestamptz(6)
  employees     employees[]
  job_positions job_positions[]
}

model job_positions {
  id             Int         @id @default(autoincrement())
  department_id  Int
  title          String      @db.VarChar(100)
  is_ot_eligible Boolean     @default(true)
  created_at     DateTime    @default(now()) @db.Timestamptz(6)
  updated_at     DateTime    @default(now()) @db.Timestamptz(6)
  employees      employees[]
  departments    departments @relation(fields: [department_id], references: [id], onDelete: Cascade)

  @@index([department_id])
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model projects {
  id          Int      @id @default(autoincrement())
  code        String?  @db.VarChar(50)
  name        String   @db.VarChar(200)
  client_name String?  @db.VarChar(200)
  address     String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)
  contact     String?  @db.VarChar(200)
  lat         Decimal? @db.Decimal(10, 8)
  lng         Decimal? @db.Decimal(11, 8)
  phone       String?  @db.VarChar(50)
  radius_m    Int      @default(200)
  status      String   @default("CURRENT") @db.VarChar(50)
}

model employee_warnings {
  id         Int       @id @default(autoincrement())
  emp_id     String    @db.VarChar(20)
  date       DateTime  @default(now()) @db.Date
  reason     String
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  employee   employees @relation(fields: [emp_id], references: [emp_id], onDelete: Cascade)

  @@index([emp_id])
  @@index([date])
}

model birthday_claims {
  id                    String    @id @db.VarChar(30)
  emp_id                String    @db.VarChar(20)
  name                  String    @db.VarChar(100)
  amount_cash           Decimal   @db.Decimal(12, 2)
  amount_meal           Decimal   @db.Decimal(12, 2)
  receipt_url           String?
  transfer_slip_url     String?
  celebration_photo_url String?
  status                String    @default("pending") @db.VarChar(20)
  created_at            DateTime  @default(now()) @db.Timestamptz(6)
  approved_by           String?   @db.VarChar(100)
  approved_at           DateTime? @db.Timestamptz(6)
  substitute_date       DateTime? @db.Date
  is_sales              Boolean   @default(false)
  employees             employees @relation(fields: [emp_id], references: [emp_id], onDelete: Cascade)
}

model travel_claims {
  id                        String    @id @default(uuid())
  emp_id                    String    @db.VarChar(20)
  date                      DateTime  @db.Date
  end_date                  DateTime? @db.Date
  claim_type                String    @db.VarChar(20)
  site_name                 String    @db.VarChar(200)
  is_overnight              Boolean   @default(false)
  accommodation_amount      Decimal   @default(0) @db.Decimal(12, 2)
  accommodation_receipt_url String?
  report_url                String
  status                    String    @default("pending_supervisor") @db.VarChar(50)
  has_pre_approval          Boolean   @default(false)
  is_supervisor_shared      Boolean   @default(false)
  supervisor_id             String?   @db.VarChar(20)
  supervisor_approved_at    DateTime? @db.Timestamptz(6)
  supervisor_remark         String?
  approved_by               String?   @db.VarChar(100)
  approved_at               DateTime? @db.Timestamptz(6)
  created_at                DateTime  @default(now()) @db.Timestamptz(6)
  remark                    String?
  employee                  employees @relation(fields: [emp_id], references: [emp_id], onDelete: Cascade)
}
